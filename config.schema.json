{
  "pluginAlias": "XiaomiRoborockMatter",
  "pluginType": "platform",
  "singular": true,
  "headerDisplay": "Expose Xiaomi Roborock vacuums as Matter Robotic Vacuum Cleaner devices.",
  "footerDisplay": "The miio token is stored in Homebridge config and is never printed by this plugin.",
  "schema": {
    "type": "object",
    "required": ["devices"],
    "properties": {
      "devices": {
        "title": "Roborock Devices",
        "type": "array",
        "minItems": 1,
        "items": {
          "title": "Roborock Device",
          "type": "object",
          "required": ["name", "ip", "token"],
          "additionalProperties": false,
          "properties": {
            "name": {
              "title": "Name",
              "type": "string",
              "default": "Roborock"
            },
            "ip": {
              "title": "IP Address",
              "type": "string",
              "format": "ipv4",
              "placeholder": "192.168.1.100"
            },
            "token": {
              "title": "miio Token",
              "type": "string",
              "pattern": "^[0-9a-fA-F]{32}$",
              "minLength": 32,
              "maxLength": 32,
              "placeholder": "32-character hex token"
            },
            "model": {
              "title": "Model Override",
              "type": "string",
              "placeholder": "rockrobo.vacuum.v1",
              "description": "Optional. Used as the Matter model before registration. Leave empty to detect from miio."
            },
            "resetId": {
              "title": "Matter Reset ID",
              "type": "string",
              "placeholder": "v2",
              "description": "Optional. Change this value to force a new Matter accessory identity when HomeKit keeps stale metadata."
            },
            "pollInterval": {
              "title": "Poll Interval (ms)",
              "type": "integer",
              "minimum": 2000,
              "default": 10000
            }
          }
        }
      }
    }
  },
  "layout": [
    {
      "key": "devices",
      "type": "array",
      "items": [
        "devices[].name",
        "devices[].ip",
        "devices[].token",
        "devices[].model",
        "devices[].resetId",
        "devices[].pollInterval"
      ]
    }
  ]
}
